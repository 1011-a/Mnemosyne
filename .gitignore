.DS_Store

# SwiftPM / Xcode build outputs
.build/
build/
.ddata/
DerivedData/
*.xcresult

# Generated by xcodegen from project.yml
Mnemosyne.xcodeproj/

# Local app bundles and generated assets
*.app/
*.dSYM/
dist/

# Local secrets and machine-specific config
.env
.env.*
!.env.example
*.pem
*.p12
*.mobileprovision
# App secrets file (normally lives in ~/Library/Application Support/Mnemosyne) — never commit
secrets.json
# Local knowledge-base data (never commit the user's indexed content)
*.sqlite
*.sqlite-*
*.db

# Local development notes and generated experiment artifacts
PROGRESS.md
.hatch-pet-runs/

# Logs
*.log
