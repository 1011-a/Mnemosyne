# Development overrides for required services.
# Most users should add their required DeepSeek API key in Mnemosyne Settings instead.

# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Required local Ollama endpoint and Gemma vision model.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_VISION_MODEL=gemma3:12b

# To load this file when launching from a shell:
# MNEMOSYNE_ENV_PATH=.env swift run Mnemosyne
