{
  "$meta": {
    "name": "Mnemosyne AI-Native Design System",
    "version": "0.1.0",
    "principles": [
      "Dark-first; depth comes from translucency and layered surfaces, not borders.",
      "The 'intelligence' gradient (iris -> cyan) is the signature of every generative surface.",
      "Provenance is first-class: citations and sources carry their own teal.",
      "Interfaces feel alive (spring motion, ambient aurora) but never jittery.",
      "Every screen composes only from these tokens and the component library."
    ]
  },
  "color": {
    "canvas": "#0A0B0F", "surface": "#12141A", "surfaceRaised": "#1A1D26", "surfaceOverlay": "#22262F",
    "borderSubtle": "rgba(255,255,255,0.06)", "borderDefault": "rgba(255,255,255,0.10)", "borderStrong": "rgba(255,255,255,0.16)",
    "textPrimary": "#F2F4F8", "textSecondary": "#A9B1C0", "textTertiary": "#6B7385", "textDisabled": "#454B59",
    "iris": "#6E56F7", "cyan": "#22D3EE", "violet": "#A855F7", "provenance": "#5EEAD4",
    "success": "#34D399", "warning": "#FBBF24", "danger": "#FB7185", "info": "#60A5FA"
  },
  "gradient": {
    "intelligence": "linear-gradient(135deg, #6E56F7, #22D3EE)",
    "aurora": "linear-gradient(90deg, #A855F7, #6E56F7, #22D3EE)"
  },
  "space": { "x1": 4, "x2": 8, "x3": 12, "x4": 16, "x5": 20, "x6": 24, "x8": 32, "x10": 40, "x12": 48, "x16": 64 },
  "radius": { "sm": 6, "md": 10, "lg": 14, "xl": 20, "xxl": 28, "pill": 999 },
  "type": {
    "display": "34/40 bold", "title1": "28/34 bold", "title2": "22/28 semibold", "title3": "17/22 semibold",
    "body": "15/22 regular", "callout": "14/20 regular", "caption": "12/16 medium", "mono": "13/20 mono"
  },
  "motion": {
    "snappy": "spring(response 0.30, damping 0.82)",
    "smooth": "spring(response 0.45, damping 0.85)",
    "bounce": "spring(response 0.50, damping 0.62)",
    "fast": "120ms easeOut", "base": "220ms easeInOut"
  },
  "elevation": {
    "e1": "0 2 8 rgba(0,0,0,0.25)", "e2": "0 8 18 rgba(0,0,0,0.35)",
    "e3": "0 18 36 rgba(0,0,0,0.45)", "glow": "0 0 24 rgba(110,86,247,0.45)"
  }
}
